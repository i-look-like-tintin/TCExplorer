# Cache files - these are generated automatically and should not be committed
php/cache/*
cache/

# Except for compressed IBTrACS data which we want to commit
!php/cache/ibtracs/
php/cache/ibtracs/*
!php/cache/ibtracs/*.csv.gz

# IBTrACS CSV files - too large for GitHub (will be auto-decompressed)
*.csv

# Node modules (if any)
node_modules/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Claude Code directory
.claude/

# Log files
*.log
error_log

# Temporary files
*.tmp
*.temp
.cache/
